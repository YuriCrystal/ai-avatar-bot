# Neon Postgres（Vercel Marketplace 建立後會自動注入）
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Clerk（Publishable Key 可公開；Secret Key 只能放伺服器環境變數）
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# 可選：設定 Clerk JWT 公鑰後，後端可不經網路驗證 token
# CLERK_JWT_KEY=-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----

# 全域管理者 Clerk User ID，可建立網站並存取所有租戶；一般網站成員由後台指派
ADMIN_USER_IDS=user_REPLACE_ME

# Token 的 azp 來源白名單；正式站與本機網址用逗號分隔
ADMIN_ALLOWED_ORIGINS=http://localhost:3000,https://YOUR-DOMAIN.example

# 正式環境建議設為 true：所有公開分析、客服與名單寫入都必須附網站公開寫入識別碼
REQUIRE_SITE_KEY=true

# 匿名問題分析的保存天數（7～730，預設 180）
ANALYTICS_RETENTION_DAYS=180

# 已結案客服案件的保存天數（30～1825，預設 365）
SUPPORT_RETENTION_DAYS=365

# 潛在客戶與預約資料的保存天數（30～1825，預設 365）
LEADS_RETENTION_DAYS=365

# 管理操作稽核紀錄保存天數（30～2555，預設 365）
AUDIT_RETENTION_DAYS=365
